{
  "@platforms": [
    "android",
    "iPhone",
    "iPad"
  ],
  "id": "__UNI__GUARDIAN01",
  "name": "guardian",
  "version": {
    "name": "1.0.0",
    "code": "100"
  },
  "description": "监护端APP",
  "developer": {
    "name": "",
    "email": "",
    "url": ""
  },
  "permissions": {
    "maps": {
      "baidu": {},
      "amap": {},
      "google": {}
    },
    "UniNView": {
      "description": "UniNView原生渲染"
    }
  },
  "plus": {
    "useragent": {
      "value": "uni-app",
      "concatenate": true
    },
    "splashscreen": {
      "target": "id:1",
      "autoclose": true,
      "waiting": true,
      "delay": 0
    },
    "popGesture": "close",
    "launchwebview": {
      "id": "1",
      "kernel": "WKWebview"
    },
    "usingComponents": true,
    "nvueStyleCompiler": "uni-app",
    "compilerVersion": 3,
    "distribute": {
      "google": {
        "permissions": [
          "<uses-permission android:name=\"android.permission.ACCESS_FINE_LOCATION\"/>",
          "<uses-permission android:name=\"android.permission.ACCESS_COARSE_LOCATION\"/>"
        ]
      },
      "apple": {},
      "plugins": {
        "audio": {
          "mp3": {
            "description": "Android平台录音支持MP3格式文件"
          }
        }
      }
    },
    "statusbar": {
      "immersed": "supportedDevice",
      "style": "dark",
      "background": "#1890ff"
    },
    "uniStatistics": {
      "enable": false
    },
    "allowsInlineMediaPlayback": true,
    "safearea": {
      "background": "#ffffff",
      "bottom": {
        "offset": "auto"
      }
    },
    "uni-app": {
      "control": "uni-v3",
      "vueVersion": "3",
      "compilerVersion": "5.07",
      "nvueCompiler": "uni-app",
      "renderer": "auto",
      "nvue": {
        "flex-direction": "column"
      },
      "nvueLaunchMode": "normal",
      "webView": {
        "minUserAgentVersion": "49.0"
      }
    },
    "tabBar": {
      "position": "bottom",
      "color": "#999999",
      "selectedColor": "#1890ff",
      "borderStyle": "rgba(0,0,0,0.4)",
      "blurEffect": "none",
      "fontSize": "10px",
      "iconWidth": "24px",
      "spacing": "3px",
      "height": "50px",
      "list": [
        {
          "pagePath": "pages/index/index",
          "text": "首页"
        },
        {
          "pagePath": "pages/alarm/index",
          "text": "告警"
        },
        {
          "pagePath": "pages/profile/index",
          "text": "我的"
        }
      ],
      "backgroundColor": "#ffffff",
      "selectedIndex": 0,
      "shown": true,
      "child": [
        "lauchwebview"
      ],
      "selected": 0
    }
  },
  "app-harmony": {
    "useragent": {
      "value": "uni-app",
      "concatenate": true
    },
    "uniStatistics": {
      "enable": false
    },
    "safearea": {
      "background": "#ffffff",
      "bottom": {
        "offset": "auto"
      }
    }
  },
  "launch_path": "__uniappview.html"
}