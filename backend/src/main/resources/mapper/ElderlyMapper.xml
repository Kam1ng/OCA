<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.eldercare.mapper.ElderlyMapper">
    <select id="findByUserId" resultType="com.example.eldercare.entity.Elderly">
        SELECT * FROM elderly WHERE user_id = #{userId} AND deleted = 0
    </select>

    <select id="selectById" resultType="com.example.eldercare.entity.Elderly">
        SELECT * FROM elderly WHERE id = #{id} AND deleted = 0
    </select>
</mapper>