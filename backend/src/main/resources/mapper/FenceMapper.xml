<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.eldercare.mapper.FenceMapper">
    <select id="findByElderlyId" resultType="com.example.eldercare.entity.Fence">
        SELECT * FROM fence WHERE elderly_id = #{elderlyId} AND deleted = 0
    </select>
</mapper>